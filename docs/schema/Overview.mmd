  Authority                 }o -- o{    Authority                 : "**UPDATES**"
  
  Authority                 }o -- o|    Authority                 : "**CORRECTS**"
  
  Authority                 }o -- o{    Authority                 : "**SUPERSEDES**"
  Authority                 }o -- o{    AuthorityGroup            : "**SUPERSEDES**"
  
