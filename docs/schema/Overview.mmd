  AuthorityGroup            }o -- o{    Authority                 : "**HAS_RELATED_AUTHORITY**<br/>(_relationship_)"
  AuthorityGroup            }o -- o{    AuthorityGroup            : "**HAS_RELATED_AUTHORITY**<br/>(_relationship_)"
  
  Authority                 }o -- o{    Authority                 : "**REFERENCES**<br/>(_referenceType_)"
